---
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/Container.astro';

import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {

    const posts = await getCollection('blog');

    return posts.map((post) => ({
        params: {
            slug: post.slug,
        },
        props: {
            post,
        },
    }));
}

const { post } = Astro.props;

const allPosts = await getCollection('blog');

const relatedPosts = allPosts
    .filter((p) =>
        p.slug !== post.slug &&
        p.data.tags.some((tag) =>
            post.data.tags.includes(tag)
        )
    )
    .slice(0, 3);

const { Content } = await render(post);
---

<Layout
    title={post.data.title}
    description={post.data.description}
>

    <Container>

        <article class="py-20 max-w-3xl">

            <h1 class="text-5xl font-bold mb-6">
                {post.data.title}
            </h1>

            <p class="text-gray-500 mb-6">
                {post.data.pubDate.toLocaleDateString('it-IT')}
            </p>

            <div class="flex flex-wrap gap-2 mb-10">

                {post.data.tags.map((tag) => (

                    <a
                        href={`/tags/${tag}`}
                        class="text-sm bg-gray-100 px-3 py-1 rounded-full hover:bg-gray-200 transition"
                    >
                        {tag}
                    </a>

                ))}

            </div>

            <div class="prose prose-lg max-w-none">

                <Content />

            </div>

            {relatedPosts.length > 0 && (

                <section class="mt-20 pt-12 border-t border-gray-200">

                    <h2 class="text-3xl font-bold mb-10">

                        Articoli correlati

                    </h2>

                    <div class="space-y-8">

                        {relatedPosts.map((related) => (

                            <article>

                                <h3 class="text-2xl font-semibold mb-2">

                                    <a
                                        href={`/blog/${related.slug}`}
                                        class="hover:underline"
                                    >
                                        {related.data.title}
                                    </a>

                                </h3>

                                <p class="text-gray-600 leading-relaxed">
                                    {related.data.description}
                                </p>

                            </article>

                        ))}

                    </div>

                </section>

            )}

        </article>

    </Container>

</Layout>