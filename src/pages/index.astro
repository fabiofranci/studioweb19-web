---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';

import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
    .filter((project) => project.data.featured)
    .slice(0, 3);

const posts = (await getCollection('blog'))
    .slice(0, 3);
---

<Layout
    title="StudioWeb19"
    description="Sviluppo software gestionali, piattaforme cloud e sistemi verticali in Laravel."
>

    <!-- HERO -->

    <section class="py-28 border-b border-gray-200">

        <Container>

            <div class="max-w-4xl">

                <p class="uppercase tracking-[0.2em] text-sm text-gray-500 mb-8">

                    Laravel • SaaS • Workflow • Data Integration

                </p>

                <h1 class="text-6xl leading-tight font-bold mb-10">

                    Sviluppo software gestionali e piattaforme cloud verticali.

                </h1>

                <p class="text-2xl text-gray-600 leading-relaxed">

                    Progetto sistemi web orientati a workflow operativi,
                    document management, integrazione dati,
                    importazioni massive e piattaforme SaaS specialistiche.

                </p>

            </div>

        </Container>

    </section>

    <!-- COMPETENZE -->

    <section class="py-24">

        <Container>

            <div class="mb-14">

                <h2 class="text-4xl font-bold mb-6">
                    Aree di lavoro
                </h2>

                <p class="text-gray-600 text-lg max-w-3xl">
                    Sviluppo piattaforme operative orientate a processi reali,
                    integrazione dati e automazione workflow.
                </p>

            </div>

            <div class="grid md:grid-cols-3 gap-10">

                <article class="border rounded-2xl p-8">

                    <h3 class="text-2xl font-semibold mb-5">
                        Software gestionali
                    </h3>

                    <p class="text-gray-600 leading-relaxed">
                        Gestionali verticali sviluppati in Laravel
                        per workflow operativi, monitoraggi,
                        pianificazione e reportistica.
                    </p>

                </article>

                <article class="border rounded-2xl p-8">

                    <h3 class="text-2xl font-semibold mb-5">
                        Integrazione dati
                    </h3>

                    <p class="text-gray-600 leading-relaxed">
                        Importazioni PDF/XLS/CSV,
                        normalizzazione dati,
                        riconciliazione e automazione processi.
                    </p>

                </article>

                <article class="border rounded-2xl p-8">

                    <h3 class="text-2xl font-semibold mb-5">
                        SaaS verticali
                    </h3>

                    <p class="text-gray-600 leading-relaxed">
                        Architetture cloud multitenant,
                        dashboard operative,
                        API REST e sistemi documentali.
                    </p>

                </article>

            </div>

        </Container>

    </section>

    <!-- APPROCCIO -->

    <section class="py-24 border-t border-gray-200">

        <Container>

            <div class="grid md:grid-cols-2 gap-16">

                <div>

                    <p class="uppercase tracking-[0.2em] text-sm text-gray-500 mb-6">
                        Approccio
                    </p>

                    <h2 class="text-4xl font-bold leading-tight">

                        Software orientato a workflow reali.

                    </h2>

                </div>

                <div class="space-y-6 text-lg text-gray-600 leading-relaxed">

                    <p>

                        I progetti vengono sviluppati partendo dai processi operativi reali,
                        con attenzione a struttura dati,
                        workflow,
                        tracciabilità
                        e mantenibilità nel tempo.

                    </p>

                    <p>

                        L'obiettivo non è soltanto creare interfacce,
                        ma costruire strumenti operativi realmente utilizzabili
                        in contesti produttivi complessi.

                    </p>

                    <p>

                        Le piattaforme sviluppate includono workflow documentali,
                        sistemi SaaS verticali,
                        integrazione dati,
                        dashboard operative
                        e automazione processi.

                    </p>

                </div>

            </div>

        </Container>

    </section>

    <!-- PROGETTI -->

    <section class="py-24 bg-gray-50 border-y border-gray-200">

        <Container>

            <div class="flex items-end justify-between mb-14">

                <div>

                    <h2 class="text-4xl font-bold mb-4">
                        Progetti
                    </h2>

                    <p class="text-gray-600">
                        Alcuni progetti e piattaforme sviluppate.
                    </p>

                </div>

                <a
                    href="/progetti"
                    class="text-sm hover:underline"
                >
                    Tutti i progetti
                </a>

            </div>

            <div class="grid md:grid-cols-3 gap-8">

                {projects.map((project) => (

                    <a
                        href={`/progetti/${project.slug}`}
                        class="group block border rounded-2xl p-8 bg-white hover:border-black transition"
                    >

                        {project.data.image && (

                            <img
                                src={project.data.image}
                                alt={project.data.title}
                                class="w-full aspect-video object-cover rounded-xl mb-6 border border-gray-200 bg-gray-100"
                            />

                        )}

                        <div class="flex items-center justify-between mb-6">

                            <h3 class="text-2xl font-semibold">
                                {project.data.title}
                            </h3>

                            <span class="text-sm text-gray-400 group-hover:text-black transition">
                                →
                            </span>

                        </div>

                        <p class="text-gray-600 mb-8 leading-relaxed">

                            {project.data.description}

                        </p>

                        <div class="flex flex-wrap gap-2">

                            {project.data.technologies.map((tech) => (

                                <span class="text-xs bg-gray-100 px-3 py-1 rounded-full">
                                    {tech}
                                </span>

                            ))}

                        </div>

                    </a>
                ))}

            </div>

        </Container>

    </section>

    <!-- BLOG -->

    <section class="py-24">

        <Container>

            <div class="flex items-end justify-between mb-14">

                <div>

                    <h2 class="text-4xl font-bold mb-4">
                        Articoli tecnici
                    </h2>

                    <p class="text-gray-600">
                        Workflow, Laravel, importazioni dati e architetture software.
                    </p>

                </div>

                <a
                    href="/blog"
                    class="text-sm hover:underline"
                >
                    Tutti gli articoli
                </a>

            </div>

            <div class="space-y-8">

                {posts.map((post) => (

                    <article class="border-b border-gray-200 pb-8">

                        <h3 class="text-2xl font-semibold mb-3">

                            <a
                                href={`/blog/${post.slug}`}
                                class="hover:underline"
                            >
                                {post.data.title}
                            </a>

                        </h3>

                        <p class="text-gray-600 leading-relaxed">
                            {post.data.description}
                        </p>

                    </article>

                ))}

            </div>

        </Container>

    </section>

    <!-- CTA -->

    <section class="py-28 border-t border-gray-200">

        <Container>

            <div class="max-w-3xl">

                <h2 class="text-5xl font-bold mb-8">

                    Progetti software orientati a workflow reali.

                </h2>

                <p class="text-xl text-gray-600 leading-relaxed mb-10">

                    Sistemi sviluppati con attenzione a struttura dati,
                    processi operativi,
                    integrazione e mantenibilità nel tempo.

                </p>

                <a
                    href="/contatti"
                    class="inline-flex items-center px-6 py-3 rounded-xl bg-black text-white hover:bg-gray-800 transition"
                >
                    Contatti
                </a>

            </div>

        </Container>

    </section>

</Layout>