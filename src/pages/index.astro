---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
---

<Layout
    title="StudioWeb19"
    description="Sviluppo software gestionali, piattaforme cloud e sistemi verticali."
>

    <section class="py-24">

        <Container>

            <div class="max-w-3xl">

                <p class="text-sm uppercase tracking-widest text-gray-500 mb-6">
                    Laravel • SaaS • Workflow • Data Integration
                </p>

                <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-8">

                    Sviluppo software gestionali e piattaforme cloud verticali.

                </h1>

                <p class="text-xl text-gray-600 leading-relaxed">

                    Progetto e sviluppo sistemi web orientati a workflow operativi,
                    importazione dati, document management, dashboard e SaaS verticali.

                </p>

            </div>

        </Container>

    </section>

</Layout>