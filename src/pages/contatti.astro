---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
---

<Layout
    title="Contatti"
    description="Contatti StudioWeb19"
>

    <Container>

        <section class="py-24 max-w-4xl">

            <p class="uppercase tracking-[0.2em] text-sm text-gray-500 mb-6">

                Contatti

            </p>

            <h1 class="text-6xl font-bold leading-tight mb-10">

                Parliamo del progetto.

            </h1>

            <p class="text-2xl text-gray-600 leading-relaxed mb-16">

                Sviluppo software gestionali,
                workflow documentali,
                piattaforme SaaS verticali
                e sistemi di integrazione dati.

            </p>

            <div class="grid md:grid-cols-2 gap-16">

                <div>

                    <h2 class="text-2xl font-semibold mb-6">
                        Contatti diretti
                    </h2>

                    <div class="space-y-4 text-lg">

                        <p>

                            Email:
                            <a
                                href="mailto:TUAMAIL"
                                class="underline"
                            >
                                TUAMAIL
                            </a>

                        </p>

                        <p>

                            GitHub:
                            <a
                                href="https://github.com/fabiofranci"
                                target="_blank"
                                class="underline"
                            >
                                github.com/fabiofranci
                            </a>

                        </p>

                    </div>

                </div>

                <div>

                    <h2 class="text-2xl font-semibold mb-6">
                        Ambiti progettuali
                    </h2>

                    <ul class="space-y-4 text-lg text-gray-600">

                        <li>Software gestionali</li>

                        <li>Workflow documentali</li>

                        <li>Piattaforme SaaS verticali</li>

                        <li>Dashboard operative</li>

                        <li>Importazione e riconciliazione dati</li>

                        <li>Automazione processi backend</li>

                    </ul>

                </div>

            </div>

        </section>

    </Container>

</Layout>