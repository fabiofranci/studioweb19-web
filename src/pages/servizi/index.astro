---
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/Container.astro';
---

<Layout
    title="Servizi"
    description="Servizi di sviluppo software e piattaforme cloud."
>

    <Container>

        <section class="py-20">

            <h1 class="text-4xl font-bold mb-10">
                Servizi
            </h1>

            <div class="space-y-10">

                <article>
                    <h2 class="text-2xl font-semibold mb-3">
                        Software gestionali
                    </h2>

                    <p class="text-gray-600">
                        Sviluppo di piattaforme operative verticali basate su Laravel.
                    </p>
                </article>

                <article>
                    <h2 class="text-2xl font-semibold mb-3">
                        Importazione dati
                    </h2>

                    <p class="text-gray-600">
                        Workflow di importazione PDF, XLS, CSV e riconciliazione dati.
                    </p>
                </article>

            </div>

        </section>

    </Container>

</Layout>